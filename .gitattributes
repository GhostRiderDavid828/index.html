<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vrei să ieși cu mine?</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fbf6f0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
            text-align: center;
        }

        .container {
            position: relative;
            padding: 20px;
        }

        img {
            width: 150px;
            margin-bottom: 20px;
        }

        h2 {
            font-size: 1.2rem;
            color: #555;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        h1 {
            font-size: 3rem;
            color: #e63946;
            margin: 10px 0 40px 0;
        }

        .buttons {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            height: 150px; /* Spațiu pentru ca butonul NO să poată fugi */
        }

        .btn {
            padding: 15px 40px;
            font-size: 1.2rem;
            font-weight: bold;
            border: none;
            border-radius: 30px;
            cursor: pointer;
            transition: transform 0.1s ease;
        }

        #yesBtn {
            background-color: #e63946;
            color: white;
            box-shadow: 0 4px 15px rgba(230, 57, 70, 0.4);
        }

        #noBtn {
            background-color: #f4a261;
            color: white;
            position: absolute; /* Permite mutarea butonului oriunde */
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Poți schimba link-ul imaginii cu orice gif/imagine drăguță -->
        <img src="https://media.giphy.com/media/v1.Y2lkPTc5MGI3NjExbWdtcmM0bnd5MW95Ym85MGptY3B1Y3g0eXFib3p3bTM0N3B0ZXZyayZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/cLS1cfxvGOPVpf9g3y/giphy.gif" alt="Cute Cupid">
        
        <h2>No pressure but... say yes 🙏</h2>
        <h1>Will you go on a date with me?</h1>

        <div class="buttons">
            <button class="btn" id="yesBtn" onclick="aiSpusDa()">Yes ✨</button>
            <button class="btn" id="noBtn" onmouseover="fugiDeCursor()" onclick="fugiDeCursor()">No</button>
        </div>
    </div>

    <script>
        const noBtn = document.getElementById('noBtn');

        // Funcția care mută butonul „No” în poziții aleatorii
        function fugiDeCursor() {
            // Calculăm lățimea și înălțimea ferestrei
            const latimeFereastra = window.innerWidth - noBtn.offsetWidth;
            const inaltimeFereastra = window.innerHeight - noBtn.offsetHeight;

            // Generăm coordonate aleatorii
            const xAleatoru = Math.floor(Math.random() * latimeFereastra);
            const yAleatoru = Math.floor(Math.random() * inaltimeFereastra);

            // Aplicăm noile coordonate butonului
            noBtn.style.left = xAleatoru + 'px';
            noBtn.style.top = yAleatoru + 'px';
        }

        // Ce se întâmplă când apasă „Yes”
        function aiSpusDa() {
            alert("Știam eu! ❤️ Ne vedem la întâlnire!");
            // Opțional, poți trimite utilizatorul către un alt site (ex: un chat de WhatsApp)
            // window.location.href = "https://wa.me/numarultau";
        }
    </script>

</body>
</html>